<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center|top"
    tools:context=".MainActivity">

    <!-- thay vì dùng layout gravity ở con mình dùng gravity ở cha để các nút ra giữA
    có thể ghép đc luôn center|top ra giữa r lên trên -->

     <Button

         android:id="@+id/button1"
         android:layout_width="wrap_content"
         android:layout_height="wrap_content"
         android:layout_marginTop="30dp"
         android:text="Nút Số 1"
         android:textSize="20dp"
         android:textColor="#41D327">

     </Button>
    <Button

         android:id="@+id/button2"
         android:layout_width="wrap_content"
         android:layout_height="wrap_content"
         android:layout_marginTop="30dp"
         android:text="Nút Số 2"
         android:textSize="20dp"

         android:textColor="#CA3F3F">

     </Button>
     <Button

         android:id="@+id/button3"
         android:layout_width="wrap_content"
         android:layout_height="wrap_content"
         android:layout_marginTop="30dp"
         android:text="Nút Số 3"
         android:textSize="20dp"
         android:textColor="#C7A7B1">

     </Button>

</LinearLayout>