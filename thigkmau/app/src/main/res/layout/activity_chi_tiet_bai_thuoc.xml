<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/mau_nen">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="centerInside"
        android:src="@drawable/logo_app"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/txtTenChiTiet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tên bài thuốc"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/xanh_la_cay"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txtNguonChiTiet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nguồn: Dân gian"
        android:textSize="16sp"
        android:textStyle="italic"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/txtNoiDungChiTiet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nội dung bài thuốc sẽ hiển thị ở đây..."
        android:textSize="18sp"
        android:lineSpacingExtra="6dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="QUAY LẠI"
        android:backgroundTint="@color/xanh_tieu_de"
        android:textColor="@color/white" />

</LinearLayout>
