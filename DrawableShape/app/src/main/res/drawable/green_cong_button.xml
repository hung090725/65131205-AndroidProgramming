<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
<!--    android:shape="rectangle" = hình dạng là hình chữ nhật
corners = phần chỉnh góc
radius="30dp" = bo tròn 4 góc với độ cong 30dp.

solid Dùng để tô màu nền chính.
Giải thích:
solid = màu nền đặc
color="#098343" = màu xanh lá đậm
 stroke Dùng để tạo viền cho shape.
Giải thích: stroke = đường viền
width="2dip" = viền dày 2 đơn vị
color="#F6DD18" = màu viền vàng
dip là dp á
padding : Dùng để tạo khoảng cách bên trong shape.
Giải thích:
top="4dp" = cách mép trên 4dp
bottom="4dp" = cách mép dưới 4dp
left="4dp" = cách mép trái 4dp
right="4dp" = cách mép phải 4dp
-->
    <corners android:radius="40dp" />

    <solid android:color="#098343" />

    <stroke
        android:width="4dp"
        android:color="#1841F6" />

    <padding
        android:bottom="4dp"
        android:left="4dp"
        android:right="4dp"
        android:top="4dp" />

</shape>