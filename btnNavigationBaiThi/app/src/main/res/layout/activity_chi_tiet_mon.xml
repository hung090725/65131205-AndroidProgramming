<?xml version="1.0" encoding="utf-8"?>
<!--
    Màn hình Chi Tiết Món Ăn.
    Hiện ra khi người dùng nhấn vào một món ăn trong danh sách.
    Nhận dữ liệu từ Intent (tên + mô tả + hình ảnh).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <!-- Thanh tiêu đề -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#3F51B5"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Quay lại"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Chi Tiết Món Ăn"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Ảnh món ăn to -->
    <ImageView
        android:id="@+id/ivChiTietAnh"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_launcher_background" />

    <!-- Tên món ăn -->
    <TextView
        android:id="@+id/tvChiTietTen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="Tên Món Ăn"
        android:textColor="@color/black"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- Đường phân cách -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:background="#E0E0E0" />

    <!-- Mô tả chi tiết -->
    <TextView
        android:id="@+id/tvChiTietMoTa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="Mô tả chi tiết về món ăn này..."
        android:textColor="#555555"
        android:textSize="16sp"
        android:lineSpacingExtra="4dp" />

</LinearLayout>
